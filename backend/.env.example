PORT=5000
NODE_ENV=development

# Comma-separated allowed browser origins (Netlify site URL(s))
# Example: https://your-app.netlify.app,https://www.yourdomain.com
FRONTEND_URL=
# CORS_ORIGIN=  # optional alias; merged with FRONTEND_URL

# Local dev: set to true to turn off API rate limiting
# DISABLE_RATE_LIMIT=true
# RATE_LIMIT_MAX_DEV=10000

# MongoDB Atlas or local — no trailing spaces
MONGODB_URI=mongodb://127.0.0.1:27017/ride-share

JWT_SECRET=

# Cloudinary — KYC / verification document storage
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=

# Google OAuth (Sign-In)
GOOGLE_CLIENT_ID=

# Google Maps — use TWO keys in Google Cloud Console (recommended)
# Browser key: restrict by HTTP referrer + enable Maps JavaScript API, Places API
GOOGLE_MAPS_BROWSER_KEY=
# Server key: restrict by IP + enable Directions, Distance Matrix, Places, Geocoding APIs
GOOGLE_MAPS_SERVER_KEY=

# Legacy single key (both sides) — not recommended for production
# GOOGLE_MAPS_API_KEY=
