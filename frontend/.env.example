# API (proxied in dev via vite.config.js)
VITE_API_BASE_URL=/api/v1

# App
VITE_APP_NAME=Ride Share
VITE_APP_ENV=development

# Google OAuth (Sign-In button)
VITE_GOOGLE_CLIENT_ID=

# Optional dev fallback for Maps JS (prefer server bootstrap in production)
# Restrict this key to your domain + Maps JavaScript API only
VITE_GOOGLE_MAPS_API_KEY=

# Socket — in dev, useAppSocket defaults to http://localhost:5000
VITE_SOCKET_URL=http://localhost:5000

# ── Netlify production (set in Site → Environment variables) ──
# VITE_API_BASE_URL=https://your-service.onrender.com/api/v1
# VITE_SOCKET_URL=https://your-service.onrender.com
# VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id
# VITE_GOOGLE_MAPS_API_KEY=your-browser-maps-key
